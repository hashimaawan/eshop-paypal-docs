{
  "Logging": {
    "Console": {
      "IncludeScopes": false
    },
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information"
    }
  },
  "PaymentOptions": {
    "UsePayPal": true,
    "PayPalClientId": "<client_id>",
    "PayPalClientSecret": "<client_secret>",
    "PayPalEnvironment": "Sandbox"
  }
}
