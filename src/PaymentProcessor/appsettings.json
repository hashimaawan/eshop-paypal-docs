{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "EventBus": "amqp://localhost"
  },
  "EventBus": {
    "SubscriptionClientName": "PaymentProcessor"
  },
  "ServiceAuth": {
    "ClientId": "paymentprocessor",
    "ClientSecret": "secret",
    "Scope": "orders"
  },
  "PaymentOptions": {
    "PaymentSucceeded": true,
    "UsePayPal": false,
    "PayPalEnvironment": "Sandbox",
    "CurrencyCode": "USD"
  }
}